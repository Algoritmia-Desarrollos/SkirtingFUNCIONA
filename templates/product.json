{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "title": {
          "type": "title",
          "settings": {}
        },
        "rating": {
          "type": "rating",
          "settings": {}
        },
        "tsf_usp_strip": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "{% render 'tsf-product-usp-strip' %}"
          }
        },
        "price": {
          "type": "price",
          "settings": {}
        },
        "inventory": {
          "type": "inventory",
          "settings": {
            "inventory_threshold": 10,
            "show_inventory_quantity": true
          }
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "button",
            "swatch_shape": "circle"
          }
        },
        "quantity_selector": {
          "type": "quantity_selector",
          "settings": {}
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": true,
            "show_gift_card_recipient": false
          }
        },
        "trust_strip_sidebar": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "<div style='border-top:1px solid rgba(var(--color-foreground),0.08);margin-top:1.6rem;padding-top:1.6rem;display:flex;flex-direction:column;gap:0.9rem;'><div style='display:flex;align-items:flex-start;gap:0.8rem;font-size:1.25rem;color:rgba(var(--color-foreground),0.75);line-height:1.4;'><span style='font-size:1.4rem;flex-shrink:0;'>🚚</span><span><strong style='color:rgb(var(--color-foreground));'>Ships same day from Texas</strong> — Order by 3PM Mon–Fri</span></div><div style='display:flex;align-items:flex-start;gap:0.8rem;font-size:1.25rem;color:rgba(var(--color-foreground),0.75);line-height:1.4;'><span style='font-size:1.4rem;flex-shrink:0;'>✅</span><span><strong style='color:rgb(var(--color-foreground));'>Satisfaction guaranteed</strong> — We stand behind every hide</span></div><div style='display:flex;align-items:flex-start;gap:0.8rem;font-size:1.25rem;color:rgba(var(--color-foreground),0.75);line-height:1.4;'><span style='font-size:1.4rem;flex-shrink:0;'>🔒</span><span><strong style='color:rgb(var(--color-foreground));'>Secure checkout</strong> — 256-bit SSL encryption</span></div><div style='display:flex;align-items:flex-start;gap:0.8rem;font-size:1.25rem;color:rgba(var(--color-foreground),0.75);line-height:1.4;'><span style='font-size:1.4rem;flex-shrink:0;'>📞</span><span><strong style='color:rgb(var(--color-foreground));'>Questions? Call Manuel</strong> — <a href='tel:+19727502810' style='color:rgb(var(--color-foreground));text-decoration:underline;'>(972) 750-2810</a> · Mon–Fri 8AM–3PM CT</span></div></div>"
          }
        }
      },
      "block_order": [
        "title",
        "rating",
        "tsf_usp_strip",
        "price",
        "inventory",
        "variant_picker",
        "quantity_selector",
        "buy_buttons",
        "trust_strip_sidebar"
      ],
      "settings": {
        "enable_sticky_info": true,
        "color_scheme": "scheme-1",
        "media_size": "large",
        "constrain_to_viewport": true,
        "media_fit": "cover",
        "gallery_layout": "thumbnail_slider",
        "mobile_thumbnails": "show",
        "media_position": "left",
        "image_zoom": "lightbox",
        "hide_variants": true,
        "enable_video_looping": false,
        "padding_top": 36,
        "padding_bottom": 12
      }
    },

    "bulk_pricing_fullwidth": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<div class=\"page-width\"><div style=\"padding: 1.5rem 2rem; border: 1px dashed rgba(var(--color-foreground),0.2); font-size: 1.4rem; border-radius: 5px; background: rgba(var(--color-foreground),0.02); text-align: center; max-width: 800px; margin-left: auto; margin-right: auto;\"><p style=\"margin:0;\"><strong>Buying 3+ sides?</strong> Call Manuel directly at (972) 750-2810 to discuss bulk volume pricing for your shop.</p></div></div>",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "trust_badges_fullwidth": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<div class=\"page-width\" style=\"text-align: center; padding: 2rem 0;\">{% render 'trust-badges' %}</div>",
        "padding_top": 0,
        "padding_bottom": 12
      }
    },
    "technical_specs": {
      "type": "collapsible-content",
      "blocks": {
        "tab_about": {
          "type": "collapsible_row",
          "settings": {
            "heading": "About this cut",
            "row_content": "<p>Our leather is selected from the thickest and strongest parts of the hide, heavily favored by saddlers making skirts and riggings for working saddles. You can expect durability and excellent structure.</p>",
            "icon": "leather"
          }
        },
        "tab_thickness": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Thickness guide",
            "row_content": "<p><strong>13-15 oz:</strong> Extra heavy. Recommended for saddle skirts, riggings, and stress points.</p><p><strong>9-10 oz:</strong> Medium/Heavy. Recommended for heavy saddlebags, chaps tops, and tooled accessories.</p>",
            "icon": "ruler"
          }
        },
        "tab_care": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Conditioning & care",
            "row_content": "<p>Our pit-tanned leather takes oil beautifully. We recommend 100% pure Neatsfoot oil or Saddle Soap for finishing and maintaining flexibility throughout the life of your craft.</p>",
            "icon": "leaf"
          }
        }
      },
      "block_order": [
        "tab_about",
        "tab_thickness",
        "tab_care"
      ],
      "settings": {
        "heading": "Technical Specifications",
        "heading_size": "h2",
        "heading_alignment": "center",
        "layout": "section",
        "container_color_scheme": "scheme-1",
        "color_scheme": "scheme-1",
        "open_first_collapsible_row": true,
        "padding_top": 24,
        "padding_bottom": 36
      }
    },
    "product_description": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<div class=\"tsf-product-description page-width\">{% if product.description != blank %}<div class=\"tsf-product-desc-inner rte\">{{ product.description }}</div>{% endif %}</div>",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "product_faq": {
      "type": "tsf-faq",
      "blocks": {
        "faq_1": {
          "type": "faq_item",
          "settings": {
            "question": "What is the difference between 1st and 2nd grade?",
            "answer": "1st grade hides are the cleanest cuts with minimal natural markings — ideal for tooled show saddles or presentation pieces. 2nd grade hides have more natural character (brands, scars) but the same structural strength, making them perfect for working saddles at a better value."
          }
        },
        "faq_2": {
          "type": "faq_item",
          "settings": {
            "question": "What thickness should I use for saddle skirts?",
            "answer": "For saddle skirts we recommend 13–14oz (Extra Heavy) or 14oz+ skirting leather. The extra weight gives your skirts the rigidity and longevity that working saddles demand. For lighter applications like saddlebags or tooled accessories, 9–10oz is a great choice."
          }
        },
        "faq_3": {
          "type": "faq_item",
          "settings": {
            "question": "How long does shipping take?",
            "answer": "We ship same day from Greenville, Texas for orders placed before 3PM Mon–Fri. Most US orders arrive in 1–3 business days. You'll receive a tracking number by email as soon as your order ships."
          }
        },
        "faq_4": {
          "type": "faq_item",
          "settings": {
            "question": "Can I call before ordering to ask about a specific hide?",
            "answer": "Absolutely. Manuel is available Mon–Fri 8AM–3PM CT at (972) 750-2810. He can walk you through current inventory, help pick the right grade and thickness, and answer any technical questions."
          }
        },
        "faq_5": {
          "type": "faq_item",
          "settings": {
            "question": "What if the leather isn't what I expected?",
            "answer": "Contact us — we'll make it right. We stand behind every hide we ship. Reach Manuel at manuel@theskirtingfactoryllc.com or (972) 750-2810 and we'll work out a solution together."
          }
        }
      },
      "block_order": [
        "faq_1",
        "faq_2",
        "faq_3",
        "faq_4",
        "faq_5"
      ],
      "settings": {
        "heading": "Common questions about this leather",
        "color_scheme": "scheme-1",
        "show_contact_cta": true,
        "padding_top": 52,
        "padding_bottom": 52
      }
    },
    "related-products": {
      "type": "related-products",
      "settings": {
        "heading": "Complete your order",
        "heading_size": "h2",
        "products_to_show": 4,
        "columns_desktop": 4,
        "columns_mobile": "2",
        "color_scheme": "scheme-2",
        "image_ratio": "square",
        "image_shape": "default",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": true,
        "padding_top": 36,
        "padding_bottom": 28
      }
    }
  },
  "order": [
    "main",
    "product_description",
    "bulk_pricing_fullwidth",
    "trust_badges_fullwidth",
    "technical_specs",
    "product_faq",
    "related-products"
  ]
}
