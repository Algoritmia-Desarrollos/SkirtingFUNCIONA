{%- style -%}
  .tsf-leather-filter {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .tsf-leather-filter__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .tsf-leather-filter__header .tsf-label {
    display: inline-block;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.18rem;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.45);
    margin-bottom: 1rem;
  }

  .tsf-leather-filter__header h2 {
    font-size: clamp(1.9rem, 4vw, 2.8rem);
    font-weight: 800;
    margin: 0 0 0.8rem;
    line-height: 1.2;
  }

  .tsf-leather-filter__header p {
    font-size: 1.5rem;
    color: rgba(var(--color-foreground), 0.6);
    margin: 0;
  }

  /* Filter pills */
  .tsf-leather-filter__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    justify-content: center;
    margin-bottom: 3rem;
  }

  .tsf-filter-pill {
    background: none;
    border: 1.5px solid rgba(var(--color-foreground), 0.15);
    border-radius: 999px;
    padding: 0.7rem 1.8rem;
    font-size: 1.3rem;
    font-weight: 600;
    color: rgba(var(--color-foreground), 0.65);
    cursor: pointer;
    transition: all 0.2s ease;
    letter-spacing: 0.02rem;
    font-family: inherit;
  }

  .tsf-filter-pill:hover {
    border-color: rgba(var(--color-foreground), 0.45);
    color: rgb(var(--color-foreground));
  }

  .tsf-filter-pill.is-active {
    background: rgb(var(--color-foreground));
    border-color: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
  }

  /* Product grid */
  .tsf-leather-filter__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  @media screen and (min-width: 750px) {
    .tsf-leather-filter__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (min-width: 990px) {
    .tsf-leather-filter__grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    }
  }

  /* Product card */
  .tsf-filter-card {
    display: flex;
    flex-direction: column;
  }

  .tsf-filter-card.is-hidden {
    display: none;
  }

  .tsf-filter-card__image-wrap {
    position: relative;
    overflow: hidden;
    border-radius: 12px;
    background: rgba(var(--color-foreground), 0.04);
    margin-bottom: 1.2rem;
    aspect-ratio: 1 / 1;
  }

  .tsf-filter-card__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
    display: block;
  }

  .tsf-filter-card__image-wrap:hover img {
    transform: scale(1.04);
  }

  .tsf-filter-card__badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: 0.05rem;
    text-transform: uppercase;
    padding: 0.3rem 0.9rem;
    border-radius: 999px;
  }

  .tsf-filter-card__title {
    font-size: 1.45rem;
    font-weight: 700;
    margin: 0 0 0.4rem;
    color: rgb(var(--color-foreground));
    line-height: 1.3;
  }

  .tsf-filter-card__title a {
    text-decoration: none;
    color: inherit;
  }

  .tsf-filter-card__title a:hover {
    text-decoration: underline;
  }

  .tsf-filter-card__price {
    font-size: 1.4rem;
    font-weight: 600;
    color: rgba(var(--color-foreground), 0.75);
  }

  .tsf-filter-card__price s {
    color: rgba(var(--color-foreground), 0.4);
    font-weight: 400;
    margin-left: 0.4rem;
  }

  /* View all button */
  .tsf-leather-filter__footer {
    text-align: center;
    margin-top: 3rem;
  }

  .tsf-leather-filter__footer .tsf-filter-view-all {
    display: inline-block;
    padding: 1.2rem 3rem;
    font-size: 1.4rem;
    font-weight: 700;
    border-radius: 999px;
    text-decoration: none;
    letter-spacing: 0.04rem;
    background: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
    transition: opacity 0.2s ease;
    font-family: inherit;
    border: none;
    cursor: pointer;
  }

  .tsf-leather-filter__footer .tsf-filter-view-all:hover {
    opacity: 0.8;
  }
{%- endstyle -%}

<div class="tsf-leather-filter color-{{ section.settings.color_scheme }} gradient" id="tsf-filter-section-{{ section.id }}">
  <div class="page-width">

    <div class="tsf-leather-filter__header">
      <span class="tsf-label">Browse the full range</span>
      <h2>{{ section.settings.heading | escape }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p>{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="tsf-leather-filter__pills" role="group" aria-label="Filter by cut">
        <button class="tsf-filter-pill is-active" data-col="__all" aria-pressed="true">All</button>
        {%- for block in section.blocks -%}
          <button
            class="tsf-filter-pill"
            data-col="{{ block.settings.collection_handle | escape }}"
            aria-pressed="false"
            {{ block.shopify_attributes }}
          >{{ block.settings.label | escape }}</button>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="tsf-leather-filter__grid" id="tsf-filter-grid-{{ section.id }}">

      {%- comment -%} ALL group: products from the default collection {%- endcomment -%}
      {%- assign default_col = collections[section.settings.collection] -%}
      {%- for product in default_col.products limit: section.settings.products_to_show -%}
        <div class="tsf-filter-card" data-group="__all">
          <a href="{{ product.url }}" class="tsf-filter-card__image-wrap" aria-label="{{ product.title | escape }}">
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | escape | default: product.title | escape }}" width="600" height="600" loading="lazy">
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
            {%- if product.compare_at_price > product.price -%}<span class="tsf-filter-card__badge">Sale</span>{%- endif -%}
          </a>
          <p class="tsf-filter-card__title"><a href="{{ product.url }}">{{ product.title | escape }}</a></p>
          <p class="tsf-filter-card__price">
            {{ product.price | money }}{%- if product.compare_at_price > product.price -%}<s>{{ product.compare_at_price | money }}</s>{%- endif -%}
          </p>
        </div>
      {%- endfor -%}

      {%- comment -%} Per-collection groups {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- assign filter_col = collections[block.settings.collection_handle] -%}
        {%- if filter_col != blank -%}
          {%- for product in filter_col.products limit: section.settings.products_to_show -%}
            <div class="tsf-filter-card is-hidden" data-group="{{ block.settings.collection_handle | escape }}">
              <a href="{{ product.url }}" class="tsf-filter-card__image-wrap" aria-label="{{ product.title | escape }}">
                {%- if product.featured_image -%}
                  <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | escape | default: product.title | escape }}" width="600" height="600" loading="lazy">
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
                {%- if product.compare_at_price > product.price -%}<span class="tsf-filter-card__badge">Sale</span>{%- endif -%}
              </a>
              <p class="tsf-filter-card__title"><a href="{{ product.url }}">{{ product.title | escape }}</a></p>
              <p class="tsf-filter-card__price">
                {{ product.price | money }}{%- if product.compare_at_price > product.price -%}<s>{{ product.compare_at_price | money }}</s>{%- endif -%}
              </p>
            </div>
          {%- endfor -%}
        {%- endif -%}
      {%- endfor -%}

    </div>

    <div class="tsf-leather-filter__footer">
      <a href="#" class="tsf-filter-view-all" id="tsf-filter-viewall-{{ section.id }}">
        {{ section.settings.view_all_label | escape }}
      </a>
    </div>

  </div>
</div>

<script>
  (function () {
    var sectionEl = document.getElementById('tsf-filter-section-{{ section.id }}');
    if (!sectionEl) return;

    var pills    = sectionEl.querySelectorAll('.tsf-filter-pill');
    var grid     = document.getElementById('tsf-filter-grid-{{ section.id }}');
    var viewAll  = document.getElementById('tsf-filter-viewall-{{ section.id }}');
    var allCards = grid.querySelectorAll('.tsf-filter-card');
    var activeGroup = '__all';

    // Collection URLs for "View All" button
    var colUrls = {
      '__all': {{ collections[section.settings.collection].url | json }}
      {%- for block in section.blocks -%}
        {%- assign bc = collections[block.settings.collection_handle] -%}
        {%- if bc != blank -%}
        , {{ block.settings.collection_handle | json }}: {{ bc.url | json }}
        {%- endif -%}
      {%- endfor -%}
    };

    function showGroup(group) {
      activeGroup = group;
      allCards.forEach(function(card) {
        card.classList.toggle('is-hidden', card.dataset.group !== group);
      });
      if (viewAll) {
        viewAll.href = colUrls[group] || colUrls['__all'] || '/collections/all';
      }
    }

    pills.forEach(function(pill) {
      pill.addEventListener('click', function() {
        pills.forEach(function(p) {
          p.classList.remove('is-active');
          p.setAttribute('aria-pressed', 'false');
        });
        this.classList.add('is-active');
        this.setAttribute('aria-pressed', 'true');
        showGroup(this.dataset.col);
      });
    });

    // Init
    showGroup('__all');
  })();
</script>

{% schema %}
{
  "name": "Leather Filter",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Cut"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Select the cut you need — every hide ships same day from Texas."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Default collection (All tab)"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 3,
      "max": 12,
      "step": 3,
      "label": "Products per filter",
      "default": 6
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "options": [
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "6", "label": "6" }
      ],
      "default": "3"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "Button label",
      "default": "View All Leathers"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "filter_tab",
      "name": "Filter Tab",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Button label",
          "default": "Sides"
        },
        {
          "type": "text",
          "id": "collection_handle",
          "label": "Collection handle",
          "info": "The handle from your Shopify collections URL (e.g. 'sides', 'double-butts')",
          "default": "sides"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Leather Filter",
      "blocks": [
        { "type": "filter_tab", "settings": { "label": "Sides", "collection_handle": "sides" } },
        { "type": "filter_tab", "settings": { "label": "Skirting Sides", "collection_handle": "skirting-sides" } },
        { "type": "filter_tab", "settings": { "label": "Double Butts", "collection_handle": "double-butts" } },
        { "type": "filter_tab", "settings": { "label": "Single Butts", "collection_handle": "single-butts" } },
        { "type": "filter_tab", "settings": { "label": "Shoulders", "collection_handle": "double-shoulders" } },
        { "type": "filter_tab", "settings": { "label": "Finished", "collection_handle": "finished-leather" } }
      ]
    }
  ]
}
{% endschema %}
