{%- style -%}
  .tsf-trust-bar {
    background: #1a1a1a;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .tsf-trust-bar__inner {
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: stretch;
    justify-content: space-between;
  }

  .tsf-trust-bar__item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.5rem;
    flex: 1;
    border-right: 1px solid rgba(255,255,255,0.08);
  }

  .tsf-trust-bar__item:last-child {
    border-right: none;
  }

  .tsf-trust-bar__icon {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    opacity: 0.85;
  }

  .tsf-trust-bar__icon svg {
    width: 100%;
    height: 100%;
    stroke: #c9a96e;
    fill: none;
    stroke-width: 1.6;
  }

  .tsf-trust-bar__text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }

  .tsf-trust-bar__title {
    font-size: 1.15rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: 0.015rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .tsf-trust-bar__desc {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Mobile: hide the text and just show icons + title only up to 3 stacked */
  @media screen and (max-width: 749px) {
    .tsf-trust-bar__inner {
      flex-direction: column;
      padding: 0;
    }

    .tsf-trust-bar__item {
      border-right: none;
      border-bottom: 1px solid rgba(255,255,255,0.07);
      padding: 1rem 2rem;
    }

    .tsf-trust-bar__item:last-child {
      border-bottom: none;
    }

    .tsf-trust-bar__desc {
      -webkit-line-clamp: 2;
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .tsf-trust-bar__desc {
      display: none;
    }
    .tsf-trust-bar__title {
      white-space: normal;
      font-size: 1.1rem;
    }
  }
{%- endstyle -%}

<div class="tsf-trust-bar">
  <div class="tsf-trust-bar__inner">
    {%- for block in section.blocks -%}
      <div class="tsf-trust-bar__item" {{ block.shopify_attributes }}>
        <div class="tsf-trust-bar__icon">
          {%- case block.settings.icon -%}
            {%- when 'truck' -%}
              <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M5 18H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h3.19M15 6h2a2 2 0 0 1 2 2v8h-2M5 18a2 2 0 1 0 4 0 2 2 0 0 0-4 0Zm10 0a2 2 0 1 0 4 0 2 2 0 0 0-4 0Z"/></svg>
            {%- when 'shield' -%}
              <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/></svg>
            {%- when 'leaf' -%}
              <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg>
            {%- else -%}
              <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
          {%- endcase -%}
        </div>
        <div class="tsf-trust-bar__text">
          <span class="tsf-trust-bar__title">{{ block.settings.title | escape }}</span>
          {%- if block.settings.description != blank -%}
            <span class="tsf-trust-bar__desc">{{ block.settings.description | escape }}</span>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Trust Bar",
  "tag": "div",
  "class": "tsf-trust-bar-section",
  "enabled_on": { "groups": ["header"] },
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "truck", "label": "Truck / Shipping" },
            { "value": "shield", "label": "Shield / Guarantee" },
            { "value": "leaf", "label": "Leaf / Eco" },
            { "value": "check", "label": "Checkmark" }
          ],
          "default": "check"
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Benefit title" },
        { "type": "textarea", "id": "description", "label": "Short description", "default": "One-line benefit description." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Bar",
      "blocks": [
        { "type": "trust_item", "settings": { "icon": "truck", "title": "Ships same day from Texas", "description": "Order by 3PM Mon–Fri and your leather ships today from Greenville, TX." } },
        { "type": "trust_item", "settings": { "icon": "shield", "title": "Satisfaction guaranteed", "description": "If the leather isn't what you expected, contact us. We'll make it right." } },
        { "type": "trust_item", "settings": { "icon": "leaf", "title": "Eco-conscious tanning", "description": "Pit-tanned with vegetable extracts using a process developed over 20 years." } }
      ]
    }
  ]
}
{% endschema %}
