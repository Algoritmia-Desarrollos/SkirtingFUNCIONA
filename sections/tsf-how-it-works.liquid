{%- style -%}
  .tsf-how-it-works {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background: rgba(var(--color-foreground), 0.03);
    border-top: 1px solid rgba(var(--color-foreground), 0.07);
    border-bottom: 1px solid rgba(var(--color-foreground), 0.07);
  }
  .tsf-how-it-works__title {
    text-align: center;
    margin-bottom: 4.5rem;
  }
  .tsf-how-it-works__title .tsf-label {
    display: inline-block;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.18rem;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.45);
    margin-bottom: 1rem;
  }
  .tsf-how-it-works__title h2 {
    font-size: clamp(1.9rem, 4vw, 2.8rem);
    font-weight: 800;
    margin: 0 0 0.8rem;
    line-height: 1.2;
  }
  .tsf-how-it-works__title p {
    font-size: 1.5rem;
    color: rgba(var(--color-foreground), 0.6);
    margin: 0 auto;
    max-width: 50rem;
    line-height: 1.6;
  }
  .tsf-how-it-works__steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    position: relative;
  }
  @media screen and (min-width: 750px) {
    .tsf-how-it-works__steps {
      grid-template-columns: repeat(4, 1fr);
      gap: 2rem;
      align-items: start;
    }
  }
  .tsf-how-it-works__step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
  }
  /* Dashed connector line between steps on desktop */
  @media screen and (min-width: 750px) {
    .tsf-how-it-works__step:not(:last-child)::after {
      content: '';
      position: absolute;
      top: 27px;
      right: -1rem;
      width: 2rem;
      height: 2px;
      border-top: 2px dashed rgba(var(--color-foreground), 0.2);
      pointer-events: none;
    }
  }
  .tsf-how-it-works__number-wrap {
    position: relative;
    margin-bottom: 1.8rem;
  }
  .tsf-how-it-works__number {
    width: 54px;
    height: 54px;
    border-radius: 50%;
    background: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
    font-size: 1.8rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 4px 14px rgba(0,0,0,0.18);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .tsf-how-it-works__step:hover .tsf-how-it-works__number {
    transform: scale(1.07);
    box-shadow: 0 6px 20px rgba(0,0,0,0.24);
  }
  .tsf-how-it-works__step-title {
    font-weight: 700;
    font-size: 1.55rem;
    margin: 0 0 0.7rem;
    color: rgb(var(--color-foreground));
    line-height: 1.3;
  }
  .tsf-how-it-works__step-text {
    font-size: 1.38rem;
    line-height: 1.65;
    color: rgba(var(--color-foreground), 0.62);
    margin: 0;
    max-width: 20rem;
  }
  .tsf-how-it-works__cta {
    text-align: center;
    margin-top: 4.5rem;
  }
  .tsf-how-it-works__cta a {
    display: inline-block;
    padding: 1.5rem 3.5rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: 1.5rem;
    letter-spacing: 0.05rem;
    text-decoration: none;
    background: rgb(var(--color-button));
    color: rgb(var(--color-button-text));
    transition: opacity 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .tsf-how-it-works__cta a:hover {
    opacity: 0.9;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(var(--color-button), 0.3);
  }
  /* Mobile step numbers */
  @media screen and (max-width: 749px) {
    .tsf-how-it-works__number {
      width: 44px;
      height: 44px;
      font-size: 1.5rem;
    }
    .tsf-how-it-works__step-title { font-size: 1.4rem; }
    .tsf-how-it-works__step-text { font-size: 1.3rem; }
  }
{%- endstyle -%}

<div class="tsf-how-it-works">
  <div class="page-width">
    <div class="tsf-how-it-works__title">
      <span class="tsf-label">The process</span>
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p>{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
    <div class="tsf-how-it-works__steps">
      {%- for block in section.blocks -%}
        <div class="tsf-how-it-works__step" {{ block.shopify_attributes }}>
          <div class="tsf-how-it-works__number-wrap">
            <div class="tsf-how-it-works__number">{{ forloop.index }}</div>
          </div>
          <h3 class="tsf-how-it-works__step-title">{{ block.settings.title }}</h3>
          <p class="tsf-how-it-works__step-text">{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
    {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
      <div class="tsf-how-it-works__cta">
        <a href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "How It Works",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "From browse to your bench in 3 days" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Simple, fast, and reliable — every time." },
    { "type": "text", "id": "cta_label", "label": "CTA Button Label", "default": "Shop All Leather" },
    { "type": "url", "id": "cta_link", "label": "CTA Button Link" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding Top", "default": 60 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding Bottom", "default": 60 }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "title", "label": "Step Title", "default": "Browse the catalog" },
        { "type": "textarea", "id": "text", "label": "Step Description", "default": "Explore our full range of Argentine veg-tan skirting leather." }
      ]
    }
  ],
  "presets": [
    {
      "name": "How It Works",
      "blocks": [
        { "type": "step", "settings": { "title": "Browse & pick your grade", "text": "Select your weight and grade. Not sure? Message Manuel directly — he'll guide you." } },
        { "type": "step", "settings": { "title": "Order with confidence", "text": "Apple Pay, Shop Pay, or card. Your transaction is 100% secure." } },
        { "type": "step", "settings": { "title": "Ships same day from TX", "text": "Order by 3PM and your sides ship today from Greenville, Texas." } },
        { "type": "step", "settings": { "title": "At your bench in ~2 days", "text": "Get to work fast. Most US orders arrive in 1–3 business days." } }
      ]
    }
  ]
}
{% endschema %}
