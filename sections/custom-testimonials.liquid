{%- style -%}
  .tsf-testimonials {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background: rgba(var(--color-foreground), 0.02);
    border-top: 1px solid rgba(var(--color-foreground), 0.07);
    border-bottom: 1px solid rgba(var(--color-foreground), 0.07);
  }

  .tsf-testimonials__header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .tsf-testimonials__header .tsf-label {
    display: inline-block;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.18rem;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.45);
    margin-bottom: 1rem;
  }

  .tsf-testimonials__header h2 {
    font-size: clamp(1.9rem, 4vw, 2.6rem);
    font-weight: 800;
    margin: 0 0 1rem;
    line-height: 1.2;
  }

  .tsf-testimonials__stars-summary {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1.35rem;
    color: rgba(var(--color-foreground), 0.6);
  }

  .tsf-testimonials__stars-summary svg {
    width: 18px;
    height: 18px;
    fill: #FAAF00;
    flex-shrink: 0;
  }

  /* Grid */
  .tsf-testimonials__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media screen and (min-width: 750px) {
    .tsf-testimonials__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Card */
  .tsf-testimonial-card {
    background: rgb(var(--color-background));
    border-radius: 16px;
    border: 1px solid rgba(var(--color-foreground), 0.08);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 2px 12px rgba(0,0,0,0.05);
  }

  .tsf-testimonial-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.1);
  }

  /* Photo at top */
  .tsf-testimonial-card__photo {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    position: relative;
    background: rgba(var(--color-foreground), 0.05);
  }

  .tsf-testimonial-card__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
    display: block;
  }

  .tsf-testimonial-card:hover .tsf-testimonial-card__photo img {
    transform: scale(1.04);
  }

  /* No photo fallback — show gradient placeholder */
  .tsf-testimonial-card__photo-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(var(--color-foreground), 0.06) 0%, rgba(var(--color-foreground), 0.02) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tsf-testimonial-card__photo-placeholder svg {
    width: 48px;
    height: 48px;
    opacity: 0.15;
  }

  /* Body */
  .tsf-testimonial-card__body {
    padding: 2.4rem 2.4rem 2.2rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .tsf-testimonial-card__stars {
    display: flex;
    gap: 3px;
    margin-bottom: 1.4rem;
  }

  .tsf-testimonial-card__stars svg {
    width: 16px;
    height: 16px;
    fill: #FAAF00;
    flex-shrink: 0;
  }

  .tsf-testimonial-card__quote {
    font-size: 1.4rem;
    line-height: 1.72;
    color: rgba(var(--color-foreground), 0.8);
    font-style: italic;
    flex-grow: 1;
    margin: 0 0 2rem;
    position: relative;
    padding-left: 1.6rem;
  }

  .tsf-testimonial-card__quote::before {
    content: '\201C';
    position: absolute;
    left: 0;
    top: -0.4rem;
    font-size: 3rem;
    line-height: 1;
    color: rgba(var(--color-foreground), 0.15);
    font-family: Georgia, serif;
    font-style: normal;
  }

  .tsf-testimonial-card__footer {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    border-top: 1px solid rgba(var(--color-foreground), 0.07);
    padding-top: 1.6rem;
    margin-top: auto;
  }

  .tsf-testimonial-card__avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: rgba(var(--color-foreground), 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 1.3rem;
    color: rgb(var(--color-foreground));
    flex-shrink: 0;
    letter-spacing: 0;
  }

  .tsf-testimonial-card__author-name {
    font-weight: 700;
    font-size: 1.35rem;
    color: rgb(var(--color-foreground));
    margin: 0 0 0.2rem;
    line-height: 1.2;
  }

  .tsf-testimonial-card__author-role {
    font-size: 1.15rem;
    color: rgba(var(--color-foreground), 0.55);
    margin: 0;
    line-height: 1.3;
  }

  /* Verified badge */
  .tsf-testimonial-card__verified {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 1.1rem;
    font-weight: 600;
    color: #5a8a5f;
    margin-top: 0.4rem;
  }

  .tsf-testimonial-card__verified svg {
    width: 13px;
    height: 13px;
    fill: #5a8a5f;
    flex-shrink: 0;
  }

  @media screen and (max-width: 749px) {
    .tsf-testimonial-card__body {
      padding: 2rem 1.8rem 1.8rem;
    }
    .tsf-testimonial-card__quote {
      font-size: 1.3rem;
    }
  }
{%- endstyle -%}

<div class="tsf-testimonials">
  <div class="page-width">

    <div class="tsf-testimonials__header">
      <span class="tsf-label">Customer reviews</span>
      <h2>{{ section.settings.heading | escape }}</h2>
      <div class="tsf-testimonials__stars-summary">
        {%- for i in (1..5) -%}
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        {%- endfor -%}
        <span>5.0 &mdash; Verified buyers</span>
      </div>
    </div>

    <div class="tsf-testimonials__grid">
      {%- for block in section.blocks -%}
        <div class="tsf-testimonial-card" {{ block.shopify_attributes }}>

          {{- '<!-- photo -->' -}}
          <div class="tsf-testimonial-card__photo">
            {%- if block.settings.photo != blank -%}
              <img src="{{ block.settings.photo | image_url: width: 800 }}" alt="{{ block.settings.author | escape }}'s work" width="800" height="600" loading="lazy">
            {%- elsif block.settings.photo_asset != blank -%}
              <img src="{{ block.settings.photo_asset | asset_url }}" alt="{{ block.settings.author | escape }}'s work" width="800" height="600" loading="lazy">
            {%- else -%}
              <div class="tsf-testimonial-card__photo-placeholder">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg>
              </div>
            {%- endif -%}
          </div>

          <div class="tsf-testimonial-card__body">
            <div class="tsf-testimonial-card__stars" aria-label="5 stars">
              {%- for i in (1..5) -%}
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {%- endfor -%}
            </div>

            <p class="tsf-testimonial-card__quote">{{ block.settings.quote | escape }}</p>

            <div class="tsf-testimonial-card__footer">
              <!-- avatar removed -->
              <div>
                <p class="tsf-testimonial-card__author-name">{{ block.settings.author | escape }}</p>
                <p class="tsf-testimonial-card__author-role">{{ block.settings.role_location | escape }}</p>
                <span class="tsf-testimonial-card__verified">
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                  Verified buyer
                </span>
              </div>
            </div>
          </div>

        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Custom Testimonials",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "What saddle makers say",
      "label": "Heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "image_picker",
          "id": "photo",
          "label": "Customer work photo"
        },
        {
          "type": "text",
          "id": "photo_asset",
          "label": "Or theme asset filename (e.g. testimonial_saddle.png)",
          "info": "Used as fallback if no photo is selected above"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "This leather tools like butter. Been using Hermann Oak for 15 years, switching to TSF permanently."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author Name",
          "default": "Jake R."
        },
        {
          "type": "text",
          "id": "role_location",
          "label": "Role / Location",
          "default": "Saddle Maker — Montana"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
