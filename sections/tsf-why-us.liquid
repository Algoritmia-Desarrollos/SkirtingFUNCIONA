{%- style -%}
  .tsf-why-us {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background: rgb(var(--color-background));
  }

  /* ---- Section header ---- */
  .tsf-why-us__section-title {
    text-align: center;
    margin-bottom: 3.5rem;
  }
  .tsf-why-us__section-title .tsf-label {
    display: inline-block;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.18rem;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.45);
    margin-bottom: 1rem;
  }
  .tsf-why-us__section-title h2 {
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 800;
    margin: 0 0 0.8rem;
    line-height: 1.2;
  }
  .tsf-why-us__section-title p {
    font-size: 1.5rem;
    color: rgba(var(--color-foreground), 0.6);
    margin: 0;
    max-width: 54rem;
    margin: 0 auto;
    line-height: 1.65;
  }

  /* ---- Cards grid ---- */
  .tsf-why-us__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media screen and (min-width: 750px) {
    .tsf-why-us__grid { grid-template-columns: repeat(3, 1fr); }
  }
  .tsf-why-us__card {
    padding: 2.8rem 2.4rem;
    border-radius: 16px;
    border: 1px solid rgba(var(--color-foreground), 0.08);
    border-top: 3px solid rgb(var(--color-foreground));
    background: rgb(var(--color-background));
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    position: relative;
    overflow: hidden;
  }
  .tsf-why-us__card::before {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, rgba(var(--color-foreground), 0.05), rgba(var(--color-foreground), 0.02));
  }
  .tsf-why-us__card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 36px rgba(0,0,0,0.1);
  }
  .tsf-why-us__icon {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: rgba(var(--color-foreground), 0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 2rem;
  }
  .tsf-why-us__icon svg {
    width: 26px;
    height: 26px;
    stroke: rgb(var(--color-foreground));
  }
  .tsf-why-us__card-title {
    font-weight: 800;
    font-size: 1.7rem;
    margin: 0 0 1rem;
    line-height: 1.25;
  }
  .tsf-why-us__card-text {
    font-size: 1.45rem;
    line-height: 1.7;
    color: rgba(var(--color-foreground), 0.7);
    margin: 0;
  }
{%- endstyle -%}

<div class="tsf-why-us">
  <div class="page-width">

    {%- comment -%} Section title {%- endcomment -%}
    <div class="tsf-why-us__section-title">
      <span class="tsf-label">Why choose us</span>
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p>{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} Benefit cards {%- endcomment -%}
    <div class="tsf-why-us__grid">
      {%- for block in section.blocks -%}
        <div class="tsf-why-us__card" {{ block.shopify_attributes }}>
          <div class="tsf-why-us__icon">
            {%- case block.settings.icon -%}
              {%- when 'truck' -%}
                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M5 18H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h3.19M15 6h2a2 2 0 0 1 2 2v8h-2M5 18a2 2 0 1 0 4 0 2 2 0 0 0-4 0Zm10 0a2 2 0 1 0 4 0 2 2 0 0 0-4 0Z"/></svg>
              {%- when 'shield' -%}
                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" /></svg>
              {%- when 'star' -%}
                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" /></svg>
              {%- when 'leaf' -%}
                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" /></svg>
              {%- else -%}
                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
            {%- endcase -%}
          </div>
          <h3 class="tsf-why-us__card-title">{{ block.settings.title }}</h3>
          <p class="tsf-why-us__card-text">{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Why Choose Us",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why saddle makers choose TSF" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "We're not just a leather supplier. We're the safest bet for your craft." },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding Top", "default": 56 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding Bottom", "default": 56 }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Benefit Card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "truck", "label": "Truck" },
            { "value": "shield", "label": "Shield" },
            { "value": "star", "label": "Star" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "check", "label": "Checkmark" }
          ],
          "default": "check"
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Benefit title" },
        { "type": "textarea", "id": "text", "label": "Description", "default": "Short explanation of why this matters to the buyer." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Choose Us",
      "blocks": [
        { "type": "card", "settings": { "icon": "truck", "title": "Ships same day from Texas", "text": "Order by 3PM Mon–Fri and your leather ships the same day from Greenville, TX. Most US saddle makers receive it within 48 hours." } },
        { "type": "card", "settings": { "icon": "star", "title": "Direct from Argentine tannery", "text": "Curtidos Reconquista has tanned premium veg-tan leather for generations. No middlemen — you get tannery quality at fair prices." } },
        { "type": "card", "settings": { "icon": "shield", "title": "Satisfaction guaranteed", "text": "If the leather isn't what you expected, contact us. We stand behind every hide we sell and will make it right." } }
      ]
    }
  ]
}
{% endschema %}
